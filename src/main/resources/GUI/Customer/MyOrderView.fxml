<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #F8F5F0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Customer.MyOrderController">

    <top>
        <!-- ══ HEADER ══ -->
        <VBox style="-fx-background-color: white; -fx-border-color: transparent transparent #E8E0D5 transparent; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">

            <!-- Title bar -->
            <HBox alignment="CENTER_LEFT" prefHeight="64" spacing="12">
                <padding><Insets left="35" right="35" /></padding>
                <Label style="-fx-font-size: 13px; -fx-opacity: 0.4;" text="📋" />
                <VBox spacing="1">
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A0C04; -fx-font-family: 'Serif';" text="Đơn hàng của tôi" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif'; -fx-font-style: italic;" text="DUT-Bakery  ·  Lịch sử mua hàng" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <!-- Search box -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #F8F5F0; -fx-border-color: #DDD0C0; -fx-border-width: 1; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 0 14 0 14;" prefHeight="38" prefWidth="240">
                    <Label style="-fx-font-size: 13px; -fx-opacity: 0.5;" text="🔍" />
                    <TextField fx:id="txtSearch" promptText="Tìm theo mã đơn..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 13px; -fx-text-fill: #3D2210; -fx-font-family: 'Serif'; -fx-prompt-text-fill: #BBA898;" HBox.hgrow="ALWAYS" />
                </HBox>
            </HBox>

            <!-- ══ THỐNG KÊ ══ -->
            <HBox spacing="0" style="-fx-background-color: #FDFAF7; -fx-border-color: #EEE5D8 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <padding><Insets bottom="16" left="35" right="35" top="16" /></padding>

                <!-- Stat 1: Tổng đơn -->
                <VBox alignment="CENTER" prefWidth="160" spacing="3">
                    <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #D4891A; -fx-font-family: 'Serif';" fx:id="lblTotalOrders" text="0" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Tổng đơn hàng" />
                </VBox>

                <Region style="-fx-background-color: #E8DDD0; -fx-pref-width: 1; -fx-min-width: 1;" />

                <!-- Stat 2: Hoàn thành -->
                <VBox alignment="CENTER" prefWidth="160" spacing="3">
                    <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2E7D32; -fx-font-family: 'Serif';" fx:id="lblDoneOrders" text="0" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Hoàn thành" />
                </VBox>

                <Region style="-fx-background-color: #E8DDD0; -fx-pref-width: 1; -fx-min-width: 1;" />

                <!-- Stat 3: Đang xử lý -->
                <VBox alignment="CENTER" prefWidth="160" spacing="3">
                    <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1565C0; -fx-font-family: 'Serif';" fx:id="lblActiveOrders" text="0" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Đang xử lý" />
                </VBox>

                <Region style="-fx-background-color: #E8DDD0; -fx-pref-width: 1; -fx-min-width: 1;" />

                <!-- Stat 4: Đã hủy -->
                <VBox alignment="CENTER" prefWidth="160" spacing="3">
                    <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #C62828; -fx-font-family: 'Serif';" fx:id="lblCancelOrders" text="0" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Đã hủy" />
                </VBox>

                <Region style="-fx-background-color: #E8DDD0; -fx-pref-width: 1; -fx-min-width: 1;" />

                <!-- Stat 5: Tổng chi tiêu -->
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="3">
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #D4891A; -fx-font-family: 'Serif';" fx:id="lblTotalSpent" text="0 đ" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Tổng chi tiêu" />
                </VBox>
            </HBox>

            <!-- ══ FILTER TABS ══ -->
            <HBox alignment="CENTER_LEFT" prefHeight="46" spacing="6" style="-fx-background-color: white; -fx-border-color: #EEE5D8 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <padding><Insets left="35" right="35" /></padding>
                <fx:define>
                    <ToggleGroup fx:id="filterGroup" />
                </fx:define>

                <ToggleButton fx:id="tabAll" mnemonicParsing="false" onAction="#handleFilter" selected="true" text="Tất cả" toggleGroup="$filterGroup" style="-fx-background-color: #D4891A; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-background-radius: 16; -fx-border-radius: 16; -fx-padding: 5 16; -fx-cursor: hand;" userData="ALL" />
                <ToggleButton fx:id="tabWaiting" mnemonicParsing="false" onAction="#handleFilter" text="⏳ Chờ xác nhận" toggleGroup="$filterGroup" style="-fx-background-color: #FFF8EE; -fx-text-fill: #D4891A; -fx-font-size: 12px; -fx-font-family: 'Serif'; -fx-background-radius: 16; -fx-border-color: #F2B950; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 5 16; -fx-cursor: hand;" userData="Chờ xác nhận" />
                <ToggleButton fx:id="tabPreparing" mnemonicParsing="false" onAction="#handleFilter" text="👨‍🍳 Đang chuẩn bị" toggleGroup="$filterGroup" style="-fx-background-color: #F0F8FF; -fx-text-fill: #1565C0; -fx-font-size: 12px; -fx-font-family: 'Serif'; -fx-background-radius: 16; -fx-border-color: #90CAF9; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 5 16; -fx-cursor: hand;" userData="Đang chuẩn bị" />
                <ToggleButton fx:id="tabShipping" mnemonicParsing="false" onAction="#handleFilter" text="🚗 Đang giao" toggleGroup="$filterGroup" style="-fx-background-color: #F3F0FF; -fx-text-fill: #6A1B9A; -fx-font-size: 12px; -fx-font-family: 'Serif'; -fx-background-radius: 16; -fx-border-color: #CE93D8; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 5 16; -fx-cursor: hand;" userData="Đang giao" />
                <ToggleButton fx:id="tabDone" mnemonicParsing="false" onAction="#handleFilter" text="✅ Hoàn thành" toggleGroup="$filterGroup" style="-fx-background-color: #F1FFF3; -fx-text-fill: #2E7D32; -fx-font-size: 12px; -fx-font-family: 'Serif'; -fx-background-radius: 16; -fx-border-color: #A5D6A7; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 5 16; -fx-cursor: hand;" userData="Hoàn thành" />
                <ToggleButton fx:id="tabCancelled" mnemonicParsing="false" onAction="#handleFilter" text="❌ Đã hủy" toggleGroup="$filterGroup" style="-fx-background-color: #FFF5F5; -fx-text-fill: #C62828; -fx-font-size: 12px; -fx-font-family: 'Serif'; -fx-background-radius: 16; -fx-border-color: #EF9A9A; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 5 16; -fx-cursor: hand;" userData="Đã hủy" />

                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblOrderCount" style="-fx-font-size: 12px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif'; -fx-font-style: italic;" text="0 đơn hàng" />
            </HBox>
        </VBox>
    </top>

    <center>
        <!-- ══ DANH SÁCH ORDER ══ -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: #F8F5F0; -fx-border-color: transparent;">
            <padding><Insets bottom="30" left="35" right="35" top="20" /></padding>
            <content>
                <VBox fx:id="orderContainer" spacing="16" style="-fx-background-color: transparent;">

                    <!-- Placeholder khi không có đơn -->
                    <StackPane fx:id="emptyPlaceholder" prefHeight="300" visible="false" managed="false">
                        <VBox alignment="CENTER" spacing="12">
                            <Label style="-fx-font-size: 56px; -fx-opacity: 0.25;" text="📋" />
                            <Label style="-fx-font-size: 17px; -fx-text-fill: #BBA898; -fx-font-family: 'Serif'; -fx-font-style: italic;" text="Bạn chưa có đơn hàng nào" />
                            <Label style="-fx-font-size: 13px; -fx-text-fill: #CCC0B0; -fx-font-family: 'Serif';" text="Hãy đặt hàng ngay để thưởng thức những món ngon từ DUT Bakery!" />
                        </VBox>
                    </StackPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
