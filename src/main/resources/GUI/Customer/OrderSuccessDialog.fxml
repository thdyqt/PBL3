<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="320.0" prefWidth="500.0" style="-fx-background-color: white; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Customer.OrderSuccessDialogController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>
                <Label text=" ✔" textFill="#10b981">
                    <font>
                        <Font size="65.0" />
                    </font>
                </Label>

                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label text="CẢM ƠN BẠN ĐÃ ĐẶT HÀNG!" textFill="#1e293b">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Mã đơn hàng của bạn là:" textFill="#64748b">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblOrderId" text="#DH123456" textFill="#0f172a">
                                    <font>
                                        <Font name="System Bold" size="15.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleViewOrder" prefHeight="45.0" prefWidth="160.0" style="-fx-background-color: #F1F5F9; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-background-radius: 8;" text="Xem đơn hàng">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleNewOrder" prefHeight="45.0" prefWidth="170.0" style="-fx-background-color: #D4891A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Tạo đơn hàng mới">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
