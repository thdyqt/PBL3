<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Card đơn hàng — Load động từ Controller -->
<VBox style="-fx-background-color: white; -fx-border-color: #EEE5D8; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Customer.OrderCardController">

    <!-- ══ HEADER CARD ══ -->
    <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="10" style="-fx-background-color: #FDFAF7; -fx-border-color: transparent transparent #EEE5D8 transparent; -fx-border-width: 0 0 1 0; -fx-background-radius: 12 12 0 0;">
        <padding><Insets left="18" right="18" /></padding>

        <!-- Mã đơn -->
        <Label style="-fx-font-size: 13px; -fx-opacity: 0.4;" text="📋" />
        <Label fx:id="lblOrderID" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3D2210; -fx-font-family: 'Serif';" text="#DH000" />

        <Label style="-fx-text-fill: #DDD0C0;" text="·" />

        <!-- Ngày đặt -->
        <Label style="-fx-font-size: 13px; -fx-opacity: 0.35;" text="🗓" />
        <Label fx:id="lblOrderDate" style="-fx-font-size: 13px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="22/04/2026" />

        <Region HBox.hgrow="ALWAYS" />

        <!-- Trạng thái -->
        <Label fx:id="lblStatus" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 4 12; -fx-background-radius: 12;" text="Chờ xác nhận" />
    </HBox>

    <!-- ══ TÊN SẢN PHẨM ══ -->
    <HBox alignment="CENTER_LEFT" prefHeight="32" spacing="6">
        <padding><Insets left="18" right="18" /></padding>
        <Label style="-fx-font-size: 12px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Sản phẩm:" />
        <Label fx:id="lblProductNames" style="-fx-font-size: 12px; -fx-text-fill: #5C3A1E; -fx-font-family: 'Serif';" text="Bánh mì thịt, Hamburger bò,..." />
    </HBox>

    <!-- ══ SCROLL ẢNH SẢN PHẨM (NGANG) ══ -->
    <ScrollPane hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" prefHeight="110" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;">
        <padding><Insets bottom="8" left="18" right="18" top="4" /></padding>
        <content>
            <HBox fx:id="imageContainer" alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: transparent;" />
        </content>
    </ScrollPane>

    <!-- ══ FOOTER CARD ══ -->
    <HBox alignment="CENTER_LEFT" prefHeight="52" spacing="10" style="-fx-border-color: #EEE5D8 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
        <padding><Insets left="18" right="18" /></padding>

        <!-- Số lượng sản phẩm -->
        <Label style="-fx-font-size: 12px; -fx-opacity: 0.4;" text="🛍" />
        <Label fx:id="lblItemCount" style="-fx-font-size: 12px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="3 món" />

        <Region HBox.hgrow="ALWAYS" />

        <!-- Tổng tiền -->
        <Label style="-fx-font-size: 13px; -fx-text-fill: #9C8472; -fx-font-family: 'Serif';" text="Tổng:" />
        <Label fx:id="lblTotal" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #D4891A; -fx-font-family: 'Serif';" text="85.000 đ" />

        <!-- Nút Hủy đơn (chỉ hiện khi Chờ xác nhận) -->
        <Button fx:id="btnCancel" onAction="#handleCancel" managed="false" visible="false" prefHeight="34" style="-fx-background-color: white; -fx-text-fill: #C62828; -fx-font-size: 12px; -fx-font-family: 'Serif'; -fx-border-color: #EF9A9A; -fx-border-width: 1; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 0 14; -fx-cursor: hand;" text="✕ Hủy đơn" />

        <!-- Nút Xem chi tiết -->
        <Button fx:id="btnDetail" onAction="#handleDetail" prefHeight="34" style="-fx-background-color: #D4891A; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Serif'; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 0 16; -fx-cursor: hand;" text="Xem chi tiết →" />
    </HBox>

</VBox>
