<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="cardBox" alignment="TOP_CENTER"
      minHeight="360.0" minWidth="240.0"
      prefHeight="360.0" prefWidth="240.0" spacing="10.0"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 15; -fx-border-width: 1.5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4);"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="GUI.Customer.CustomerProductCardController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="5.0">
            <children>
                <Label fx:id="lblPrice" style="-fx-text-fill: #E11D48;" text="0 đ">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblStatus" style="-fx-background-color: #DCFCE7; -fx-text-fill: #166534; -fx-background-radius: 5; -fx-padding: 3 8;" text="Còn hàng">
                    <font><Font name="System Bold" size="11.0" /></font>
                </Label>
            </children>
        </HBox>

        <StackPane prefHeight="170.0" prefWidth="210.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10;">
            <children>
                <ImageView fx:id="imgProduct" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </StackPane>

        <Label fx:id="lblName" alignment="CENTER" prefHeight="50.0" prefWidth="210.0"
               style="-fx-text-fill: #0F172A;" text="Tên bánh" textAlignment="CENTER" wrapText="true">
            <font><Font name="System Bold" size="16.0" /></font>
        </Label>

        <Region VBox.vgrow="ALWAYS" />

        <HBox spacing="10.0">
            <children>
                <Button fx:id="btnDetails" onAction="#handleViewDetails" prefHeight="40.0"
                        style="-fx-background-color: #F1F5F9; -fx-text-fill: #0F172A; -fx-background-radius: 8; -fx-font-weight: bold;"
                        text="Xem chi tiết" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308">
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
                <Button fx:id="btnAddToCart" onAction="#handleAddToCart" prefHeight="40.0" prefWidth="50.0"
                        style="-fx-background-color: #D4891A; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" text="🛒">
                    <font><Font size="18.0" /></font>
                    <cursor><Cursor fx:constant="HAND" /></cursor>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>