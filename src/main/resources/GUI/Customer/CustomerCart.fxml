<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Customer.CustomerCartController">
    <children>
        <HBox spacing="25.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Giỏ hàng của bạn" textFill="#1E293B">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleClearCart" style="-fx-background-color: transparent; -fx-text-fill: #EF4444;" text="Xóa tất cả">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F8FAFC; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxCartItems" spacing="10.0">
                                    <padding>
                                        <Insets bottom="10.0" right="10.0" top="5.0" />
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox maxWidth="350.0" minWidth="350.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 5); -fx-padding: 25;">
                    <children>
                        <Label text="Chi tiết đơn hàng" textFill="#1E293B">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <Separator />

                        <VBox spacing="8.0">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Thông tin giao hàng" textFill="#64748B" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleEditDeliveryInfo" style="-fx-background-color: transparent; -fx-text-fill: #2563EB; -fx-padding: 0;" text="Chỉnh sửa">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                                <Label fx:id="lblDeliveryInfo" style="-fx-font-weight: bold;" text="Chưa có thông tin" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Mã giảm giá (Voucher)" textFill="#64748B" />
                                <ComboBox fx:id="cbbVoucher" prefHeight="40.0" prefWidth="300.0" promptText="Chọn hoặc nhập mã" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;" />
                            </children>
                        </VBox>

                        <Separator />

                        <VBox spacing="12.0">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Tạm tính" textFill="#64748B" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblSubTotal" text="0đ" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Giảm giá" textFill="#64748B" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblDiscount" text="0đ" textFill="#10B981" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Tổng cộng" textFill="#1E293B">
                                            <font>
                                                <Font name="System Bold" size="18.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblTotal" text="0đ" textFill="#D4891A">
                                            <font>
                                                <Font name="System Bold" size="20.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Button fx:id="btnCheckout" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCheckout" prefHeight="50.0" style="-fx-background-color: #D4891A; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 10;" text="THANH TOÁN NGAY">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>