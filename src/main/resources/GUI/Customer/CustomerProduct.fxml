<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Customer.CustomerProductController">

    <top>
        <VBox style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0">
                    <padding>
                        <Insets left="30.0" right="30.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="2.0">
                            <children>
                                <Label text="Thực Đơn Cửa Hàng" textFill="#0F172A">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>
                                <Label text="DUT-Bakery  ·  Sản phẩm tươi mới mỗi ngày" textFill="#64748B">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnToggleFilter" mnemonicParsing="false" onAction="#handleToggleFilter" prefHeight="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;" text="Ẩn bộ lọc">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                            <padding>
                                <Insets left="15.0" right="15.0" />
                            </padding>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>

                        <Label fx:id="lblResultCount" text="Hiển thị 0 sản phẩm" textFill="#475569">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Region prefHeight="1.0" style="-fx-background-color: #E2E8F0;" />
            </children>
        </VBox>
    </top>

    <center>
        <HBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
            </padding>
            <children>

                <VBox fx:id="paneFilter" prefWidth="280.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 20;">
                    <children>
                        <Label text="Tìm kiếm &amp; Lọc" textFill="#0F172A">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Tên sản phẩm" textFill="#475569">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Label>
                                <TextField fx:id="txtSearch" prefHeight="40.0" promptText="🔍 Nhập tên bánh..." style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Danh mục" textFill="#475569">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Label>
                                <ComboBox fx:id="cbCategory" prefHeight="40.0" prefWidth="250.0" promptText="Tất cả danh mục" style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Khoảng giá (VNĐ)" textFill="#475569">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Label>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <TextField fx:id="txtMinPrice" prefHeight="40.0" promptText="Từ..." style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
                                        <Label text="-" textFill="#64748B" />
                                        <TextField fx:id="txtMaxPrice" prefHeight="40.0" promptText="Đến..." style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-color: #CBD5E1; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <Button fx:id="btnClearFilter" mnemonicParsing="false" onAction="#handleClearFilter" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #FFF1F2; -fx-text-fill: #E11D48; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Xóa tất cả bộ lọc" />
                    </children>
                </VBox>

                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>

                        <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-padding: 0 20 0 20;">
                            <children>
                                <Label text="Sắp xếp theo:" textFill="#64748B">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <ComboBox fx:id="cbSort" prefHeight="32.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-cursor: hand;" />
                            </children>
                        </HBox>

                        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <AnchorPane style="-fx-background-color: transparent;">
                                    <children>
                                        <GridPane fx:id="gridProducts" hgap="25.0" vgap="25.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                        </GridPane>
                                    </children>
                                </AnchorPane>
                            </content>
                        </ScrollPane>

                    </children>
                </VBox>

            </children>
        </HBox>
    </center>
</BorderPane>
