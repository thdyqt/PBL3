<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" prefHeight="700.0" prefWidth="1050.0" style="-fx-background-color: #F8FAFC;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.BillManagementForm">
    <top>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <Label prefHeight="30.0" prefWidth="240.0" text="Lịch sử giao dịch" textFill="#1E293B">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="30.0" prefWidth="380.0" promptText="Tìm kiếm theo ID của đơn hàng/ nhân viên/ khách hàng" style="-fx-background-color: #F1F5F9; -fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6;" />
                  <ComboBox fx:id="cbbSearchOption" prefWidth="150.0" />
                        <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="buttonOrderDetail" mnemonicParsing="false" text="Xem chi tiết hóa đơn" />
                  <Button fx:id="buttonOrderReceipt" mnemonicParsing="false" text="Xuất hóa đơn" />


                    </children>
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
                    </padding>
                </HBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </top>

    <center>
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" BorderPane.alignment="CENTER">
            <children>
                <TableView fx:id="tbOrder" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="col_OrderID" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colProcessTime" prefWidth="100.0" text="Thời gian&#10;   xử lý" />
                        <TableColumn fx:id="colProcessStaffName" prefWidth="150.0" text="Nhân viên thực hiện" />
                        <TableColumn fx:id="col_StaffID" minWidth="0.0" prefWidth="95.0" text="      ID&#10;Nhân viên" />
                        <TableColumn fx:id="col_CustomerName" minWidth="0.0" prefWidth="150.0" text="Khách hàng" />
                        <TableColumn fx:id="col_CustomerID" prefWidth="95.0" text="         ID&#10; Khách hàng" />
                  <TableColumn fx:id="col_PhoneCustomer" prefWidth="167.0" text="SĐT Khách hàng" />
                  <TableColumn fx:id="col_OrderStatus" prefWidth="105.0" text="Trạng thái" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
            <BorderPane.margin>
                <Insets bottom="20.0" left="20.0" right="20.0" />
            </BorderPane.margin>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>
