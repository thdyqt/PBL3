<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainPane" prefHeight="700.0" prefWidth="1050.0" style="-fx-background-color: #F8FAFC;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.StaffManagementForm">
   <top>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Quản lý hóa đơn" textFill="#1E293B">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
               <children>
                  <TextField fx:id="txtSearch" prefHeight="30.0" prefWidth="359.0" promptText="Tìm kiếm theo ID/ Nhân viên thực hiện/ Khách hàng" style="-fx-background-color: #F1F5F9; -fx-background-radius: 6; -fx-border-color: #E2E8F0; -fx-border-radius: 6;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#btnAddClick" prefHeight="35.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" text="+ Thêm">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>
                  <Button fx:id="btnEdit" mnemonicParsing="false" onAction="#btnEditClick" prefHeight="35.0" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" text="✍ Sửa">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>

                  <Button fx:id="btnResign" mnemonicParsing="false" onAction="#btnResignClick" prefHeight="35.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" text="✖ Xóa">
                     <cursor><Cursor fx:constant="HAND" /></cursor>
                  </Button>

               </children>
               <padding>
                  <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>

   <center>
      <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tblStaff" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="47.0" text="ID" />
                  <TableColumn fx:id="colName" prefWidth="187.0" text="Thời gian thực hiện" />
                  <TableColumn fx:id="colPhone" prefWidth="160.0" text="Nhân viên thực hiện" />
                  <TableColumn fx:id="colUsername" prefWidth="113.0" text="Khách hàng" />
                  <TableColumn fx:id="colRole" prefWidth="299.0" text="Nội dung đơn hàng" />
                  <TableColumn fx:id="colDate" prefWidth="173.0" text="Trạng thái đơn hàng" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" />
         </BorderPane.margin>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
