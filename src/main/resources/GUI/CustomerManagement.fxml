<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" prefHeight="700.0" prefWidth="1050.0" style="-fx-background-color: #F8FAFC;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.CustomerManagementForm">
    <children>
        <BorderPane>
            <top>
                <VBox spacing="15.0" BorderPane.alignment="CENTER">
                    <children>
                        <Label text="Quản lý Khách hàng" textFill="#1E293B">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                            <children>

                                <TextField fx:id="txtSearch" onAction="#Search" prefWidth="250.0" promptText="🔍 Tìm kiếm tên, số điện thoại..." style="-fx-background-color: #F1F5F9; -fx-background-radius: 5; -fx-padding: 8 12; -fx-text-fill: #1E293B;">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </TextField>

                                <ComboBox fx:id="cbbSort" prefWidth="150.0" promptText="Sắp xếp theo..." style="-fx-background-color: #F1F5F9; -fx-background-radius: 5; -fx-padding: 4 8;" />

                                <Button fx:id="btnSort" mnemonicParsing="false" onAction="#btnSortClick" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 15;" text="Sắp xếp">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#btnAddClick" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 15;" text="+ Thêm mới">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>
                                <Button fx:id="btnEdit" mnemonicParsing="false" onAction="#btnEditClick" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 15;" text="✏ Sửa thông tin">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
                            </padding>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </top>

            <center>
                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" BorderPane.alignment="CENTER">
                    <BorderPane.margin>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="0.0" />
                    </BorderPane.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <TableView fx:id="tableCustomer" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colSTT" prefWidth="50.0" text="STT" />
                                <TableColumn fx:id="colName" prefWidth="220.0" text="Họ và Tên" />
                                <TableColumn fx:id="colPhone" prefWidth="150.0" text="Số điện thoại" />
                        <TableColumn fx:id="colUser" prefWidth="150.0" text="Tài khoản" />
                                <TableColumn fx:id="colPoint" prefWidth="120.0" text="Điểm tích lũy" />
                                <TableColumn fx:id="colRank" prefWidth="150.0" text="Hạng thành viên" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>
