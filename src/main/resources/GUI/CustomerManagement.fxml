<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@style.css" styleClass="customer-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.CustomerManagementForm">
    <children>
        <BorderPane styleClass="customer-border-pane">
            <effect>
                <DropShadow blurType="GAUSSIAN" height="15.0" radius="7.0" width="15.0">
                    <color><Color opacity="0.05" /></color>
                </DropShadow>
            </effect>

            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="15.0" styleClass="customer-header-bar" BorderPane.alignment="CENTER">
                    <children>
                        <Label text="Tìm kiếm:" textFill="#475569">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>

                        <TextField fx:id="txtSearch" onAction="#Search" prefWidth="250.0" promptText="Nhập tên, số điện thoại..." styleClass="customer-search-box" />
                        <ComboBox prefWidth="150.0" styleClass="customer-combo-box" />

                        <Label text="Sắp xếp theo:" textFill="#475569">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>

                        <ComboBox fx:id="cbbSort" prefWidth="160.0" styleClass="customer-combo-box" />

                        <Button fx:id="btnSort" mnemonicParsing="false" onAction="#btnSortClick" styleClass="action-btn, btn-filter" text="Lọc">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <effect>
                                <DropShadow blurType="GAUSSIAN" offsetY="2.0" radius="3.0">
                                    <color><Color opacity="0.2" /></color>
                                </DropShadow>
                            </effect>
                        </Button>

                        <Button fx:id="btnEdit" mnemonicParsing="false" onAction="#btnEditClick" styleClass="action-btn, btn-edit-item" text="✎ Sửa">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <effect>
                                <DropShadow blurType="GAUSSIAN" offsetY="2.0" radius="3.0">
                                    <color><Color opacity="0.2" /></color>
                                </DropShadow>
                            </effect>
                        </Button>

                        <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#btnAddClick" styleClass="action-btn, btn-add-item" text="+ Thêm mới">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <effect>
                                <DropShadow blurType="GAUSSIAN" offsetY="2.0" radius="3.0">
                                    <color><Color opacity="0.2" /></color>
                                </DropShadow>
                            </effect>
                        </Button>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox styleClass="customer-table-container" BorderPane.alignment="CENTER">
                    <children>
                        <TableView fx:id="tableCustomer" styleClass="customer-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colSTT" prefWidth="50.0" text="STT" />
                                <TableColumn fx:id="colId" prefWidth="120.0" text="Mã Khách" />
                                <TableColumn fx:id="colName" prefWidth="220.0" text="Tên Khách Hàng" />
                                <TableColumn fx:id="colPhone" prefWidth="150.0" text="Số Điện Thoại" />
                                <TableColumn fx:id="colPoint" prefWidth="120.0" text="Điểm Tích Lũy" />
                                <TableColumn fx:id="colRank" prefWidth="150.0" text="Hạng Thành Viên" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>