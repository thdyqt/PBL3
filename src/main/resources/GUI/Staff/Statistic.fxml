<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<StackPane fx:id="rootPane" prefHeight="800.0" prefWidth="1150.0" style="-fx-background-color: #F8FAFC;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Staff.StatisticController">
    <children>
        <BorderPane>
            <top>
                <VBox spacing="15.0" BorderPane.alignment="CENTER">
                    <children>
                        <Label text="Thống kê &amp; Báo cáo" textFill="#1E293B">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                            <children>
                                <DatePicker fx:id="dpStartDate" prefHeight="35.0" prefWidth="140.0" promptText="Từ ngày" style="-fx-background-color: #F1F5F9; -fx-background-radius: 5;" />
                                <Label text="-" textFill="#64748B">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <DatePicker fx:id="dpEndDate" prefHeight="35.0" prefWidth="140.0" promptText="Đến ngày" style="-fx-background-color: #F1F5F9; -fx-background-radius: 5;" />

                                <TextField fx:id="txtStaffSearch" prefHeight="35.0" prefWidth="200.0" promptText="🔍 Tìm ID, Tên, User NV..." style="-fx-background-color: #F1F5F9; -fx-background-radius: 5; -fx-padding: 0 10;" />

                                <ComboBox fx:id="cbTimeFilter" prefHeight="35.0" prefWidth="150.0" promptText="Lọc nhanh..." style="-fx-background-color: #F1F5F9; -fx-background-radius: 5;" />

                                <Button fx:id="btnFilter" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 0 20;" text="Lọc dữ liệu">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button fx:id="btnExport" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 0 20;" text="📥 Xuất báo cáo (Excel)">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                </Button>
                            </children>
                            <padding>
                                <Insets left="15.0" right="15.0" />
                            </padding>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" style="-fx-background: #F8FAFC; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="20.0">
                            <children>
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox alignment="CENTER" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 15px; -fx-text-fill: #64748B;" text="Tổng doanh thu" />
                                                <Label fx:id="lblTotalRevenue" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;" text="0 đ" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 15px; -fx-text-fill: #64748B;" text="Tổng đơn hoàn thành" />
                                                <Label fx:id="lblTotalOrders" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #10B981;" text="0" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 15px; -fx-text-fill: #64748B;" text="Sản phẩm đã bán" />
                                                <Label fx:id="lblTotalProducts" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" text="0" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 15px; -fx-text-fill: #64748B;" text="Tỉ lệ hủy đơn" />
                                                <Label fx:id="lblCancelRate" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #EF4444;" text="0%" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 15;" text="Biểu đồ Doanh thu" />
                                                <BarChart fx:id="chartRevenue" animated="false" prefHeight="350.0">
                                                    <xAxis>
                                                        <CategoryAxis side="BOTTOM" />
                                                    </xAxis>
                                                    <yAxis>
                                                        <NumberAxis side="LEFT" />
                                                    </yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                        <VBox prefWidth="400.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 15;" text="Tỉ trọng Nguồn đơn" />
                                                <PieChart fx:id="pieChartSource" animated="false" labelsVisible="false" legendSide="RIGHT" prefHeight="350.0" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 15;" text="Top 10 Sản phẩm bán chạy nhất" />
                                                <TableView fx:id="tableTopProducts" prefHeight="250.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colProdSTT" prefWidth="50.0" style="-fx-alignment: CENTER;" text="STT" />
                                                        <TableColumn fx:id="colProdName" prefWidth="250.0" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" text="Tên bánh" />
                                                        <TableColumn fx:id="colProdQuantity" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Đã bán" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-padding: 15;" text="Top Khách hàng chi tiêu" />
                                                <TableView fx:id="tableTopCustomers" prefHeight="250.0" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colCusSTT" prefWidth="50.0" style="-fx-alignment: CENTER;" text="STT" />
                                                        <TableColumn fx:id="colCusName" prefWidth="200.0" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" text="Khách hàng" />
                                                        <TableColumn fx:id="colCusTotal" prefWidth="150.0" style="-fx-alignment: CENTER_RIGHT; -fx-padding: 0 15 0 0;" text="Tổng chi tiêu" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </children>
</StackPane>
