<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="260.0" prefWidth="450.0"
            style="-fx-background-color: white;
                   -fx-border-color: #E2E8F0; -fx-border-width: 1;
                   -fx-border-radius: 8; -fx-background-radius: 8;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="GUI.Staff.CategoryDialogController">
    <children>
        <VBox spacing="25.0"
              AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="35.0"
              AnchorPane.rightAnchor="35.0"  AnchorPane.topAnchor="25.0">
            <children>

                <!-- TIÊU ĐỀ -->
                <VBox spacing="5.0">
                    <children>
                        <Label fx:id="lblTitle" text="THÊM DANH MỤC MỚI" textFill="#0F172A">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <Label fx:id="lblDesc"
                               text="Vui lòng điền đầy đủ thông tin bên dưới để tiếp tục."
                               textFill="#64748B">
                            <font><Font size="13.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <!-- FORM -->
                <GridPane hgap="15.0" vgap="18.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0"
                                           minWidth="10.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="38.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <!-- Tên danh mục -->
                        <Label text="Tên danh mục:" textFill="#334155" />
                        <TextField fx:id="txtCategoryName" prefHeight="38.0"
                                   promptText="VD: Bánh mì, Đồ uống..."
                                   style="-fx-background-color: #F8FAFC;
                                          -fx-background-radius: 6;
                                          -fx-border-color: #CBD5E1;
                                          -fx-border-radius: 6;
                                          -fx-padding: 0 10;"
                                   GridPane.columnIndex="1" />
                    </children>
                </GridPane>

                <!-- NÚT HỦY / LƯU -->
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button fx:id="btnCancel" text="Hủy bỏ"
                                onAction="#handleCancel"
                                prefHeight="40.0" prefWidth="110.0"
                                style="-fx-background-color: #F1F5F9;
                                       -fx-text-fill: #475569;
                                       -fx-background-radius: 6;
                                       -fx-font-size: 14px;">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button fx:id="btnSave" text="Lưu thông tin"
                                onAction="#handleSave"
                                prefHeight="40.0" prefWidth="130.0"
                                style="-fx-background-color: #D4891A;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 6;
                                       -fx-font-size: 14px;">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>