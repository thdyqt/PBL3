<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #F8FAFC;" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Staff.StaffHomeController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label fx:id="lblGreeting" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Xin chào, Staff Name!" />
                        <Label fx:id="lblDate" style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="Hôm nay là..." />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="5.0">
                    <children>
                        <Label fx:id="lblTime" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;" text="00:00:00" />
                        <Label fx:id="lblShift" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10B981;" text="Ca làm việc" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <HBox spacing="20.0">
                    <children>
                        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="Đơn chờ xác nhận" />
                                <Label fx:id="lblWaiting" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="Đơn đang xử lý" />
                                <Label fx:id="lblProcessing" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="Đơn đã hoàn thành" />
                                <Label fx:id="lblFinished" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #10B981;" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #64748B;" text="Doanh thu trong ca" />
                                <Label fx:id="lblRevenue" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #EF4444;" text="0 đ" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Thao tác nhanh:" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnPOS" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 20 0 20;" text="🛒 Bán hàng tại quầy">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Button fx:id="btnOnlineOrder" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 20 0 20;" text="📝 Quản lý đơn Online">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Button fx:id="btnInventory" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 20 0 20;" text="📦 Kiểm tra tồn kho">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                </HBox>
                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Đơn hàng Online" />
                                <TableView fx:id="tableRecentOrders" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colOrderID" prefWidth="60.0" style="-fx-alignment: CENTER;" text="ID" />
                                        <TableColumn fx:id="colCustomer" prefWidth="150.0" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15;" text="Khách hàng" />
                                        <TableColumn fx:id="colTime" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Thời gian" />
                                        <TableColumn fx:id="colTotal" prefWidth="120.0" style="-fx-alignment: CENTER_RIGHT; -fx-padding: 0 15 0 0;" text="Tổng tiền" />
                                        <TableColumn fx:id="colStatus" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Trạng thái" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                        <VBox prefWidth="350.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #EF4444;" text="Cảnh báo hết hàng" />
                                <ListView fx:id="listLowStock" style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 6;" VBox.vgrow="ALWAYS" />
                            </children>
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                        </VBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>
