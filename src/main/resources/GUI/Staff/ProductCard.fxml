<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<VBox fx:id="cardContainer" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="240.0" prefWidth="180.0" spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 15; -fx-border-width: 1.5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Staff.ProductCardController">

    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
    </padding>

    <effect>
        <DropShadow blurType="GAUSSIAN" height="15.0" radius="7.0" width="15.0">
            <color>
                <Color opacity="0.08" />
            </color>
        </DropShadow>
    </effect>

    <cursor>
        <Cursor fx:constant="HAND" />
    </cursor>

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="lblProductId" text="#SP001" textFill="#94A3B8">
                    <font>
                        <Font name="System Bold" size="11.0" />
                    </font>
                </Label>
            </children>
        </HBox>

        <StackPane prefHeight="100.0" prefWidth="100.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10;">
            <VBox.margin>
                <Insets bottom="5.0" top="2.0" />
            </VBox.margin>
            <children>
                <ImageView fx:id="imgProduct" fitHeight="90.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </StackPane>

        <Label fx:id="lblProductName" alignment="CENTER" prefHeight="35.0" prefWidth="156.0" text="Bánh Croissant Bơ Tỏi Hàn Quốc" textAlignment="CENTER" textFill="#1E293B" wrapText="true">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Label>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="BOTTOM_CENTER">
            <children>
                <VBox alignment="BOTTOM_LEFT">
                    <children>
                        <Label text="Còn lại:" textFill="#64748B">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblStock" text="25" textFill="#2563EB">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="lblPrice" text="35.000đ" textFill="#EF4444">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </children>
</VBox>