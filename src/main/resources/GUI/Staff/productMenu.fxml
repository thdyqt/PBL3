<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: #2C1A0E;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Staff.productMenuController">

    <!-- ═══════════════════════════════════════════
         BACKGROUND TEXTURE LAYER (wood grain effect)
         ═══════════════════════════════════════════ -->
    <center>
        <StackPane>

            <!-- Grain overlay background -->
            <Region style="                 -fx-background-color:                     radial-gradient(center 20% 20%, radius 60%, #4A2C17 0%, transparent 70%),                     radial-gradient(center 80% 80%, radius 50%, #3B1F0D 0%, transparent 60%),                     linear-gradient(to bottom right, #2C1A0E 0%, #3D2210 40%, #2A180C 100%);                 -fx-opacity: 1;             " />

            <!-- Wood grain lines (decorative) -->
            <Region style="                 -fx-background-color: transparent;                 -fx-border-color: transparent;                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 40, 0, 0, 0);             " />

            <!-- Main content VBox -->
            <VBox alignment="CENTER" spacing="0" style="-fx-background-color: transparent;">

                <!-- ── TOP HEADER PANEL ── -->
                <StackPane prefHeight="200" prefWidth="900">

                    <!-- Header background with rustic gradient -->
                    <Region style="                         -fx-background-color:                             linear-gradient(to bottom,                                 rgba(20,10,5,0.95) 0%,                                 rgba(44,26,14,0.85) 60%,                                 rgba(44,26,14,0.0) 100%);                     " />

                    <!-- Decorative top border stripe -->
                    <VBox alignment="TOP_CENTER">
                        <Region prefHeight="6" prefWidth="900" style="-fx-background-color: linear-gradient(to right, transparent, #D4891A, #F2B950, #D4891A, transparent);" />
                    </VBox>

                    <!-- Header content -->
                    <VBox alignment="CENTER" spacing="6">
                        <padding><Insets bottom="10" top="20" /></padding>
   
                        <!-- Bread emoji row -->
                        <Label style="                                    -fx-font-size: 28px;                                    -fx-text-fill: #F2B950;                                    -fx-effect: dropshadow(gaussian, rgba(210,130,20,0.6), 12, 0, 0, 4);                                " text="🍞  🥐  🍰  🥖  🧁" />

                        <!-- Shop name -->
                        <Label style="                                    -fx-font-size: 48px;                                    -fx-font-weight: bold;                                    -fx-text-fill: #F5DEB3;                                    -fx-font-family: 'Serif';                                    -fx-effect:                                        dropshadow(gaussian, rgba(210,130,20,0.8), 20, 0, 0, 3),                                        dropshadow(gaussian, rgba(0,0,0,0.9), 6, 0, 2, 2);                                " text="DUT-Bakery" />

                        <!-- Tagline -->
                        <Label style="                                    -fx-font-size: 15px;                                    -fx-text-fill: #C8A96E;                                    -fx-font-family: 'Serif';                                    -fx-font-style: italic;                                    -fx-letter-spacing: 1.5;                                " text="✦  Tiệm Bánh Thơm Ngon Mỗi Ngày  ✦" />

                        <!-- Decorative divider -->
                        <HBox alignment="CENTER" spacing="8">
                            <Region prefHeight="1" prefWidth="120" style="-fx-background-color: linear-gradient(to right, transparent, #D4891A);" />
                            <Label style="-fx-text-fill: #D4891A; -fx-font-size: 18px;" text="❧" />
                            <Region prefHeight="1" prefWidth="120" style="-fx-background-color: linear-gradient(to left, transparent, #D4891A);" />
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- ── MENU SECTION TITLE ── -->
                <VBox alignment="CENTER" spacing="8">
                    <padding><Insets bottom="20" top="10" /></padding>
                    <Label style="                                -fx-font-size: 13px;                                -fx-text-fill: #A0785A;                                -fx-font-family: 'Serif';                                -fx-letter-spacing: 4;                                -fx-font-weight: bold;                            " text="BẢNG ĐIỀU KHIỂN" />
                </VBox>

                <!-- ── TWO MAIN BUTTONS ── -->
                <HBox alignment="CENTER" spacing="30">
                    <padding><Insets bottom="40" left="60" right="60" /></padding>

                    <!-- Button 1: Quản Lí Sản Phẩm -->
                    <StackPane fx:id="btnProductPane" prefHeight="200" prefWidth="340" style="                                    -fx-cursor: hand;                                ">
                        <!-- Card background -->
                        <Region style="                             -fx-background-color:                                 linear-gradient(to bottom right,                                     #5C3317 0%,                                     #3E2010 50%,                                     #2E1608 100%);                             -fx-background-radius: 16;                             -fx-border-color: #8B5A2B;                             -fx-border-width: 2;                             -fx-border-radius: 16;                             -fx-effect:                                 dropshadow(gaussian, rgba(0,0,0,0.7), 20, 0, 0, 8),                                 innershadow(gaussian, rgba(212,137,26,0.15), 10, 0, 0, 2);                         " />

                        <!-- Warm glow top accent -->
                        <VBox alignment="TOP_CENTER">
                            <Region prefHeight="4" prefWidth="340" style="                                         -fx-background-color: linear-gradient(to right,                                             transparent 5%,                                             #D4891A 30%,                                             #F2B950 50%,                                             #D4891A 70%,                                             transparent 95%);                                         -fx-background-radius: 16 16 0 0;                                     " />
                        </VBox>

                        <!-- Button content -->
                        <VBox alignment="CENTER" spacing="14">
                            <Label style="-fx-font-size: 48px;                                 -fx-effect: dropshadow(gaussian, rgba(242,185,80,0.5), 10, 0, 0, 2);" text="🥖" />
                            <Label style="                                        -fx-font-size: 20px;                                        -fx-font-weight: bold;                                        -fx-text-fill: #F5DEB3;                                        -fx-font-family: 'Serif';                                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 4, 0, 1, 1);                                    " text="Quản Lí Sản Phẩm" />
                            <Label style="                                        -fx-font-size: 12px;                                        -fx-text-fill: #A0785A;                                        -fx-font-family: 'Serif';                                        -fx-font-style: italic;                                    " text="Thêm · Sửa · Ngừng kinh doan Sản Phẩm" />

                            <!-- Small decorative line -->
                            <Region prefHeight="1" prefWidth="80" style="-fx-background-color: #6B3F1E;" />

                            <Button fx:id="btnProductM" onAction="#handleProductManagement" style="                                         -fx-background-color: linear-gradient(to bottom, #D4891A, #A85F10);                                         -fx-text-fill: #FFF8EE;                                         -fx-font-size: 13px;                                         -fx-font-family: 'Serif';                                         -fx-font-weight: bold;                                         -fx-background-radius: 20;                                         -fx-padding: 8 24 8 24;                                         -fx-cursor: hand;                                         -fx-border-color: #F2B950;                                         -fx-border-width: 1;                                         -fx-border-radius: 20;                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 6, 0, 0, 3);                                     " text="Mở Quản Lí →" />
                        </VBox>
                    </StackPane>

                    <!-- Button 2: Quản Lí Danh Mục -->
                    <StackPane fx:id="btnCategoryPane" prefHeight="200" prefWidth="340" style="-fx-cursor: hand;">
                        <!-- Card background -->
                        <Region style="                             -fx-background-color:                                 linear-gradient(to bottom right,                                     #4A2B10 0%,                                     #331A08 50%,                                     #261208 100%);                             -fx-background-radius: 16;                             -fx-border-color: #7A4F28;                             -fx-border-width: 2;                             -fx-border-radius: 16;                             -fx-effect:                                 dropshadow(gaussian, rgba(0,0,0,0.7), 20, 0, 0, 8),                                 innershadow(gaussian, rgba(212,137,26,0.10), 10, 0, 0, 2);                         " />

                        <!-- Warm glow top accent -->
                        <VBox alignment="TOP_CENTER">
                            <Region prefHeight="4" prefWidth="340" style="                                         -fx-background-color: linear-gradient(to right,                                             transparent 5%,                                             #B5710F 30%,                                             #D4891A 50%,                                             #B5710F 70%,                                             transparent 95%);                                         -fx-background-radius: 16 16 0 0;                                     " />
                        </VBox>

                        <!-- Button content -->
                        <VBox alignment="CENTER" spacing="14">
                            <Label style="-fx-font-size: 48px;                                 -fx-effect: dropshadow(gaussian, rgba(242,185,80,0.5), 10, 0, 0, 2);" text="🍰" />
                            <Label style="                                        -fx-font-size: 20px;                                        -fx-font-weight: bold;                                        -fx-text-fill: #F5DEB3;                                        -fx-font-family: 'Serif';                                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 4, 0, 1, 1);                                    " text="Quản Lí Danh Mục" />
                            <Label style="                                        -fx-font-size: 12px;                                        -fx-text-fill: #906840;                                        -fx-font-family: 'Serif';                                        -fx-font-style: italic;                                    " text="Thêm - Sửa - Ngừng kinh doanh" />

                            <!-- Small decorative line -->
                            <Region prefHeight="1" prefWidth="80" style="-fx-background-color: #5C3010;" />

                            <Button fx:id="btnCategory" onAction="#handleCategoryManagement" style="                                         -fx-background-color: linear-gradient(to bottom, #B5710F, #8C4E08);                                         -fx-text-fill: #FFF8EE;                                         -fx-font-size: 13px;                                         -fx-font-family: 'Serif';                                         -fx-font-weight: bold;                                         -fx-background-radius: 20;                                         -fx-padding: 8 24 8 24;                                         -fx-cursor: hand;                                         -fx-border-color: #D4891A;                                         -fx-border-width: 1;                                         -fx-border-radius: 20;                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 6, 0, 0, 3);                                     " text="Mở Quản Lí →" />
                        </VBox>
                    </StackPane>
                </HBox>

                <!-- ── FOOTER ── -->
                <StackPane prefHeight="60">
                    <VBox alignment="CENTER" spacing="4">
                        <HBox alignment="CENTER" spacing="8">
                            <Region prefHeight="1" prefWidth="200" style="-fx-background-color: linear-gradient(to right, transparent, #5C3317);" />
                            <Label style="-fx-font-size: 14px;" text="🌾" />
                            <Region prefHeight="1" prefWidth="200" style="-fx-background-color: linear-gradient(to left, transparent, #5C3317);" />
                        </HBox>
                        <Label style="                                    -fx-font-size: 11px;                                    -fx-text-fill: #5C3A1E;                                    -fx-font-family: 'Serif';                                    -fx-font-style: italic;                                " text="DUT-Bakery © 2026  –  Freshly Baked Every Day" />
                    </VBox>
                </StackPane>

            </VBox>
        </StackPane>
    </center>
</BorderPane>
