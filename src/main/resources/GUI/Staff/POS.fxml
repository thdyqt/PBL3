<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<HBox fx:id="mainPane" prefHeight="768.0" prefWidth="1200.0" spacing="20.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Staff.POS">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <children>
                <Label text="MÀN HÌNH BÁN HÀNG (POS)" textFill="#0F172A">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER_LEFT" minHeight="65.0" prefHeight="65.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12;">
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                    <effect>
                        <DropShadow blurType="GAUSSIAN" height="10.0" radius="4.5" width="10.0">
                            <color><Color opacity="0.05" /></color>
                        </DropShadow>
                    </effect>
                    <children>
                        <TextField fx:id="txtSearchProduct" prefHeight="40.0" prefWidth="300.0" promptText="🔍 Tìm tên hoặc mã bánh..." style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label minWidth="-Infinity" text="Danh mục:" textFill="#64748B">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <ComboBox fx:id="cbbCategory" minWidth="160.0" prefHeight="40.0" prefWidth="200.0" promptText="Tất cả sản phẩm" style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="flowPaneProducts" hgap="20.0" style="-fx-padding: 5;" vgap="20.0" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <VBox maxWidth="520.0" minWidth="480.0" prefWidth="500.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15;">
            <effect>
                <DropShadow blurType="GAUSSIAN" height="20.0" radius="9.5" width="20.0">
                    <color><Color opacity="0.08" /></color>
                </DropShadow>
            </effect>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <VBox spacing="8.0">
                    <children>
                        <Label text="Khách hàng" textFill="#1E293B">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <TextField fx:id="txtCustomerPhone" onAction="#searchCustomerByPhone" prefHeight="38.0" promptText="Nhập số điện thoại..." style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnAddCustomer" minWidth="38.0" mnemonicParsing="false" onAction="#handleAddCustomer" prefHeight="38.0" prefWidth="38.0" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" text="+">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                    <font><Font size="16.0" /></font>
                                </Button>
                            </children>
                        </HBox>
                        <Label fx:id="lblCustomerName" text="Khách vãng lai" textFill="#64748B">
                            <font><Font name="System Italic" size="13.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <Separator prefWidth="200.0" />

                <Label text="Chi tiết đơn hàng" textFill="#1E293B">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>

                <TableView fx:id="tableCart" prefHeight="200.0" style="-fx-background-color: white; -fx-control-inner-background: white; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-table-cell-border-color: #F8FAFC;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSTT" maxWidth="35.0" minWidth="35.0" prefWidth="35.0" style="-fx-alignment: CENTER;" text="STT" />
                        <TableColumn fx:id="colProductName" prefWidth="170.0" text="Sản phẩm" />
                        <TableColumn fx:id="colPrice" maxWidth="80.0" minWidth="80.0" prefWidth="80.0" style="-fx-alignment: CENTER-RIGHT;" text="Đơn giá" />
                        <TableColumn fx:id="colQuantity" maxWidth="85.0" minWidth="85.0" prefWidth="85.0" style="-fx-alignment: CENTER;" text="SL" />
                        <TableColumn fx:id="colTotal" maxWidth="85.0" minWidth="85.0" prefWidth="85.0" style="-fx-alignment: CENTER-RIGHT;" text="T.Tiền" />
                        <TableColumn fx:id="colAction" maxWidth="50.0" minWidth="50.0" prefWidth="50.0" style="-fx-alignment: CENTER;" text="" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Separator prefWidth="200.0" />

                <GridPane vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="25.0" vgrow="SOMETIMES" /> <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Tổng cộng:" textFill="#64748B">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <Label fx:id="lblSubtotal" text="0 VNĐ" textFill="#1E293B" GridPane.columnIndex="1">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>

                        <Label text="Tổng số lượng:" textFill="#64748B" GridPane.rowIndex="1">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <Label fx:id="lblTotalQuantity" text="0 món" textFill="#1E293B" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>

                        <Label text="Mã giảm giá:" textFill="#64748B" GridPane.rowIndex="2">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <ComboBox fx:id="cbbDiscount" prefHeight="32.0" prefWidth="160.0" promptText="Chọn mã..." style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label fx:id="lblDiscountTitle" text="Giảm giá (0%):" textFill="#10B981" GridPane.rowIndex="3">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Label fx:id="lblDiscountAmount" text="-0 VNĐ" textFill="#10B981" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <font><Font name="System Bold" size="15.0" /></font>
                        </Label>

                        <Label text="THÀNH TIỀN" textFill="#0F172A" GridPane.rowIndex="4">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <Label fx:id="lblTotalPay" text="0 VNĐ" textFill="#2563EB" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                    </children>
                </GridPane>

                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancelOrder" prefHeight="50.0" prefWidth="120.0" style="-fx-background-color: #FEE2E2; -fx-text-fill: #EF4444; -fx-font-weight: bold; -fx-background-radius: 10;" text="Hủy đơn">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button fx:id="btnPayment" maxWidth="Infinity" mnemonicParsing="false" onAction="#handlePayment" prefHeight="50.0" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 10;" text="THANH TOÁN" HBox.hgrow="ALWAYS">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>
